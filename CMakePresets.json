{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 18,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "tests",
      "hidden": false,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/tests",
      "cacheVariables": {
        "CSPOT_TARGET_TESTS": "ON",
        "CSPOT_DISABLE_TESTS": "OFF",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "cli",
      "hidden": false,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/cli",
      "cacheVariables": {
        "CSPOT_TARGET_CLI": "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "tests",
      "configurePreset": "tests",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "cli",
      "configurePreset": "cli",
      "inheritConfigureEnvironment": true
    }
  ]
}
